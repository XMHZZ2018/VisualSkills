# OS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
venv/
.venv/

# Downloaded videos and raw subtitles (reproducible via batch scripts)
preprocess/**/assets/**/*.mp4
preprocess/**/assets/**/*.vtt

# Sparse frames from videos (reproducible via batch_extract.py)
preprocess/**/assets/**/frames/

# Skill pipeline downloaded videos and frames (reproducible via generate.py)
preprocess/skill-pipeline/data/**/videos/

# Evaluation workspaces and cache (generated on VM).
# Per-pipeline workspace/, outputs/*/plan|workers|skill/ are ignored in
# preprocess/skill-pipeline/{stage1,stage2}/.gitignore.
workspaces/
cache/
*.log

# Node
node_modules/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Env / secrets
.env
.env.*

# Slides — meeting decks and their one-off generator/fix scripts
*.pptx
/make_slides*.py
scripts/fix_slide*.py
scripts/rebuild_slide*.py
scripts/split_slide*.py
scripts/update_slides*.py
scripts/make_chevron_reference_fig.py
